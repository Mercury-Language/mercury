#---------------------------------------------------------------------------#
# vim: ts=4 sw=4 expandtab ft=sh
#---------------------------------------------------------------------------#

# Inter-module optimization changes the diagnostics for some tests
# (in most cases reporting diagnostics when writing the `.opt' file).
# For those tests, we just disable inter-module optimization.
MCFLAGS-exported_unify3         += --no-intermodule-optimization
MCFLAGS-import_in_parent        += --no-intermodule-optimization
MCFLAGS-import_in_parent        += --warn-unused-imports
MCFLAGS-import_in_parent.sub    += --no-intermodule-optimization
MCFLAGS-missing_parent_import   += --no-intermodule-optimization
MCFLAGS-sub_visibility_a1       += --no-intermodule-optimization
MCFLAGS-sub_visibility_a2       += --no-intermodule-optimization
MCFLAGS-sub_visibility_a3       += --no-intermodule-optimization
MCFLAGS-sub_visibility_a4       += --no-intermodule-optimization
MCFLAGS-sub_visibility_b1       += --no-intermodule-optimization
MCFLAGS-sub_visibility_b2       += --no-intermodule-optimization
MCFLAGS-sub_visibility_b3       += --no-intermodule-optimization
MCFLAGS-sub_visibility_b4       += --no-intermodule-optimization
MCFLAGS-sub_visibility_c1       += --no-intermodule-optimization
MCFLAGS-sub_visibility_c2       += --no-intermodule-optimization
MCFLAGS-sub_visibility_c3       += --no-intermodule-optimization
MCFLAGS-sub_visibility_c4       += --no-intermodule-optimization
MCFLAGS-sub_visibility_d1       += --no-intermodule-optimization
MCFLAGS-sub_visibility_d2       += --no-intermodule-optimization
MCFLAGS-sub_visibility_d3       += --no-intermodule-optimization
MCFLAGS-sub_visibility_d4       += --no-intermodule-optimization
MCFLAGS-subtype_submodule       += --no-intermodule-optimization
MCFLAGS-undef_mod_qual          += --no-intermodule-optimization
MCFLAGS-unresolved_overloading  += --no-intermodule-optimization
