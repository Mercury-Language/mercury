=== Test negate/1 ===

PASS: negate(zero_duration) = zero_duration
PASS: negate(negate(duration(0, 0, 0, 0))) = duration(0, 0, 0, 0)
PASS: negate(negate(duration(14, 3, 14706, 7))) = duration(14, 3, 14706, 7)
PASS: negate(negate(duration(-14, -3, -14706, -7))) = duration(-14, -3, -14706, -7)
PASS: negate(negate(duration(30, 100, 36990, 300))) = duration(30, 100, 36990, 300)
PASS: negate(negate(duration(-30, -100, -36990, -300))) = duration(-30, -100, -36990, -300)

